# 1) Copy this file to `.env` in the project root (same folder as app.py).
# 2) Default stack uses Google Gemini — set GEMINI_API_KEY from https://aistudio.google.com/apikey
# 3) For OpenAI instead: set LLM_PROVIDER=openai and OPENAI_API_KEY=sk-...
# 4) Restart Streamlit after saving `.env`.
# Never commit `.env` (it is gitignored).

LLM_PROVIDER=gemini

# Google Gemini (default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
